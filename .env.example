# Groq API key — server-side only, used by api/ask.js.
# Groq (console.groq.com) has a genuine free tier: no credit card
# required, access to every model, generous rate limits for a small
# app like this one. Sign up and create a key at:
#   https://console.groq.com/keys
# Never commit your real key. This file is only a template — set the
# real value in Vercel's dashboard (Project → Settings → Environment
# Variables), not in a committed .env file.
GROQ_API_KEY=your-groq-api-key-here

# Optional — restrict api/ask.js to only accept requests whose
# Origin/Referer starts with this URL (your deployed Vercel URL).
# Leave unset during initial testing, set it once you know your URL.
ALLOWED_ORIGIN=https://your-app.vercel.app

# Optional — override the default model.
# llama-3.3-70b-versatile (default) = best quality on the free tier.
# llama-3.1-8b-instant = fastest, highest free-tier rate limits, if
# you expect a lot of traffic and want to avoid 429s.
# GROQ_MODEL=llama-3.3-70b-versatile
